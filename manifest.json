{
  "manifest_version": 3,
  "name": "Google Drive Image Copy",
  "version": "1.0.0",
  "description": "Copy images from Google Drive to clipboard with right-click",
  "permissions": [
    "contextMenus",
    "activeTab",
    "clipboardWrite",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://drive.google.com/*",
    "https://*.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://drive.google.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}